<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Parola Girişi</title>
    <link rel="stylesheet" href="/style.css" />
</head>
<body class="page">
    <div class="login-shell">
        <div class="brand-badge">Mercedes Control Panel</div>

        <div class="card login-card">
            <h1>Parola Gerekli</h1>
            <p>Hoş geldin <%= user.username %>. Devam etmek için parola gir.</p>

            <% if (error) { %>
                <div class="gate-error"><%= error %></div>
            <% } %>

            <form method="POST" action="/gate" class="gate-form">
                <input
                    class="input"
                    type="password"
                    name="password"
                    placeholder="Parola"
                    autocomplete="off"
                    required
                />
                <button class="btn btn-primary" type="submit">Devam Et</button>
            </form>

            <p class="muted">Parola: Berkcan</p>
        </div>
    </div>
</body>
</html>
